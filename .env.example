# ── FiveClaw environment variables ──────────────────────────────────────────
# Copy to .env and fill in values. None are required at startup — the agent
# guides you through setup via its web UI at http://localhost:3777

# ── Hyperspace idle-compute ──────────────────────────────────────────────────
# Set HYPERSPACE_NODE_URL to automatically enable idle P2P compute earnings.
# FiveClaw contributes GPU/CPU to Hyperspace when it has no active tasks.
# Requires hyperspace-x-node daemon running at this URL.
HYPERSPACE_NODE_URL=http://localhost:9099

# Optional: gateway key to authenticate with hyperspace-x-node
# Must match HYPERSPACE_GATEWAY_KEY in hyperspace-x-node's .env
HYPERSPACE_GATEWAY_KEY=

# Hyperspace profile: inference | embedding | relay | storage | full
HYPERSPACE_PROFILE=inference
